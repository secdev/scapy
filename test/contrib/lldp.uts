assert tlv.scid_svid_list[0].scid == 1
assert tlv.scid_svid_list[0].svid == 2
assert tlv.scid_svid_list[1].scid == 0x123
assert tlv.scid_svid_list[1].svid == 0x456

= CDCP TLV: build and dissect

