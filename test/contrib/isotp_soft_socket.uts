        if size_to_send > 7:
            data_str = "00 {} {}".format("%02X" % size_to_send, " ".join(["%02X" % x for x in range(size_to_send)]))
            data_str_offset = 6
        else:
            data_str = "{} {}".format("%02X" % size_to_send, " ".join(["%02X" % x for x in range(size_to_send)]))
            data_str_offset = 2
        s.send(ISOTP(dhex(data_str[data_str_offset:])))
