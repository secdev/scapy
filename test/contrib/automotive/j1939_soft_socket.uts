+ J1939 constants and helpers

= J1939_GLOBAL_ADDRESS is 0xFF
assert J1939_GLOBAL_ADDRESS == 0xFF

= J1939_MAX_SF_DLEN is 8
assert J1939_MAX_SF_DLEN == 8

= J1939_TP_MAX_DLEN is 1785 (255 packets * 7 bytes)
assert J1939_TP_MAX_DLEN == 1785

= TP_CM control byte constants
assert TP_CM_RTS == 0x10
assert TP_CM_CTS == 0x11
assert TP_CM_EndOfMsgACK == 0x13
assert TP_CM_BAM == 0x20
assert TP_Conn_Abort == 0xFF

= _j1939_can_id builds 29-bit identifiers correctly
can_id = _j1939_can_id(7, 0xEC, 0xFF, 0x11)
assert can_id == 0x1CECFF11, "Expected 0x1CECFF11, got 0x{:08X}".format(can_id)
can_id = _j1939_can_id(6, 0xEC, 0x22, 0x11)
assert can_id == 0x18EC2211, "Expected 0x18EC2211, got 0x{:08X}".format(can_id)
can_id = _j1939_can_id(6, 0xEB, 0xFF, 0x11)
assert can_id == 0x18EBFF11, "Expected 0x18EBFF11, got 0x{:08X}".format(can_id)

= _j1939_decode_can_id round-trips correctly
for prio, pf, ps, sa in [(7, 0xEC, 0xFF, 0x11), (6, 0xEB, 0x22, 0xFE), (3, 0xFE, 0xCA, 0x80)]:
    can_id = _j1939_can_id(prio, pf, ps, sa)
    decoded = _j1939_decode_can_id(can_id)
    assert decoded == (prio, pf, ps, sa), "Round-trip failed: in=({},{},{},{}) out={}".format(prio, pf, ps, sa, decoded)

= _pgn_from_can_id extracts PGN correctly
can_id = _j1939_can_id(7, 0xEC, 0x22, 0x11)
assert _pgn_from_can_id(can_id) == 0xEC00
can_id = _j1939_can_id(7, 0xEB, 0x22, 0x11)
assert _pgn_from_can_id(can_id) == 0xEB00
can_id = _j1939_can_id(6, 0xFE, 0xCA, 0x11)
assert _pgn_from_can_id(can_id) == 0xFECA


+ J1939 Packet

= J1939 packet construction
p = J1939(pgn=0xFECA, src_addr=0x11, dst_addr=0xFF, data=b"\x01\x02\x03")
assert p.pgn == 0xFECA
assert p.src_addr == 0x11
assert p.dst_addr == 0xFF
assert p.data == b"\x01\x02\x03"

= J1939 packet default destination is global address
p = J1939(pgn=0xFECA, src_addr=0x11, data=b"\x01")
assert p.dst_addr == J1939_GLOBAL_ADDRESS

= J1939 packet equality
p1 = J1939(pgn=0xFECA, src_addr=0x11, dst_addr=0xFF, data=b"\xAB\xCD")
p2 = J1939(pgn=0xFECA, src_addr=0x11, dst_addr=0xFF, data=b"\xAB\xCD")
assert p1 == p2
p3 = J1939(pgn=0xFECA, src_addr=0x11, dst_addr=0xFF, data=b"\xAB\xCE")
assert p1 != p3


+ J1939SocketImplementation -- BAM receive (direct injection via on_can_recv)

= BAM receive of a 9-byte message (2 TP.DT packets)
def test_bam_rx_9bytes():
    pgn = 0xFECA
    pgn_bytes = struct.pack("<I", pgn)[:3]
    bam_data = struct.pack("B", TP_CM_BAM) + struct.pack("<H", 9) + struct.pack("B", 2) + b"\xFF" + pgn_bytes
    bam_can_id = _j1939_can_id(7, J1939_TP_CM_PF, J1939_GLOBAL_ADDRESS, 0x80)
    dt1_data = b"\x01" + b"\x01\x02\x03\x04\x05\x06\x07"
    dt2_data = b"\x02" + b"\x08\x09\xFF\xFF\xFF\xFF\xFF"
    dt_can_id = _j1939_can_id(7, J1939_TP_DT_PF, J1939_GLOBAL_ADDRESS, 0x80)
    with J1939SoftSocket(TestSocket(CAN), src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=pgn) as s:
        s.impl.on_can_recv(CAN(identifier=bam_can_id, flags="extended", data=bam_data))
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=dt1_data))
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=dt2_data))
        result = s.impl.rx_queue.recv()
        assert result is not None
        msg, ts, rx_pgn, rx_sa, rx_da = result
        assert msg == b"\x01\x02\x03\x04\x05\x06\x07\x08\x09", "Got: {}".format(msg.hex())

test_bam_rx_9bytes()

= BAM receive of a 14-byte message (2 full TP.DT packets)
def test_bam_rx_14bytes():
    pgn = 0xFECA
    pgn_bytes = struct.pack("<I", pgn)[:3]
    total_size = 14
    num_packets = 2
    bam_data = struct.pack("B", TP_CM_BAM) + struct.pack("<H", total_size) + struct.pack("B", num_packets) + b"\xFF" + pgn_bytes
    bam_can_id = _j1939_can_id(7, J1939_TP_CM_PF, J1939_GLOBAL_ADDRESS, 0x80)
    dt_can_id = _j1939_can_id(7, J1939_TP_DT_PF, J1939_GLOBAL_ADDRESS, 0x80)
    payload = bytes(range(1, 15))
    dt1_data = b"\x01" + payload[0:7]
    dt2_data = b"\x02" + payload[7:14]
    with J1939SoftSocket(TestSocket(CAN), src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=pgn) as s:
        s.impl.on_can_recv(CAN(identifier=bam_can_id, flags="extended", data=bam_data))
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=dt1_data))
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=dt2_data))
        result = s.impl.rx_queue.recv()
        assert result is not None
        msg, ts, rx_pgn, rx_sa, rx_da = result
        assert msg == payload, "Got: {}".format(msg.hex())

test_bam_rx_14bytes()

= BAM receive -- wrong PGN is ignored
def test_bam_rx_wrong_pgn():
    pgn = 0xFECA
    other_pgn = 0xFECB
    pgn_bytes = struct.pack("<I", other_pgn)[:3]
    bam_data = struct.pack("B", TP_CM_BAM) + struct.pack("<H", 9) + struct.pack("B", 2) + b"\xFF" + pgn_bytes
    bam_can_id = _j1939_can_id(7, J1939_TP_CM_PF, J1939_GLOBAL_ADDRESS, 0x80)
    with J1939SoftSocket(TestSocket(CAN), src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=pgn) as s:
        s.impl.on_can_recv(CAN(identifier=bam_can_id, flags="extended", data=bam_data))
        assert s.impl.rx_state == 0, "Expected IDLE state, got {}".format(s.impl.rx_state)
        assert s.impl.rx_queue.empty()

test_bam_rx_wrong_pgn()

= BAM receive -- rx_pgn=0 accepts any PGN and propagates actual PGN
def test_bam_rx_any_pgn():
    pgn_to_send = 0xFECA
    pgn_bytes = struct.pack("<I", pgn_to_send)[:3]
    bam_data = struct.pack("B", TP_CM_BAM) + struct.pack("<H", 9) + struct.pack("B", 2) + b"\xFF" + pgn_bytes
    bam_can_id = _j1939_can_id(7, J1939_TP_CM_PF, J1939_GLOBAL_ADDRESS, 0x80)
    dt_can_id = _j1939_can_id(7, J1939_TP_DT_PF, J1939_GLOBAL_ADDRESS, 0x80)
    dt1_data = b"\x01" + b"\xAA" * 7
    dt2_data = b"\x02" + b"\xBB\xCC\xFF\xFF\xFF\xFF\xFF"
    with J1939SoftSocket(TestSocket(CAN), src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=0) as s:
        s.impl.on_can_recv(CAN(identifier=bam_can_id, flags="extended", data=bam_data))
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=dt1_data))
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=dt2_data))
        result = s.impl.rx_queue.recv()
        assert result is not None
        msg, ts, rx_pgn, rx_sa, rx_da = result
        assert rx_pgn == 0xFECA, "BAM PGN should be 0xFECA, got 0x{:05X}".format(rx_pgn)
        assert rx_sa == 0x80, "BAM SA should be 0x80, got 0x{:02X}".format(rx_sa)

test_bam_rx_any_pgn()

= BAM receive -- sequence number error resets state machine
def test_bam_rx_sn_error():
    pgn = 0xFECA
    pgn_bytes = struct.pack("<I", pgn)[:3]
    bam_data = struct.pack("B", TP_CM_BAM) + struct.pack("<H", 9) + struct.pack("B", 2) + b"\xFF" + pgn_bytes
    bam_can_id = _j1939_can_id(7, J1939_TP_CM_PF, J1939_GLOBAL_ADDRESS, 0x80)
    dt_can_id = _j1939_can_id(7, J1939_TP_DT_PF, J1939_GLOBAL_ADDRESS, 0x80)
    dt1_data = b"\x01" + b"\x01\x02\x03\x04\x05\x06\x07"
    dt_wrong = b"\x03" + b"\x08\x09\xFF\xFF\xFF\xFF\xFF"
    with J1939SoftSocket(TestSocket(CAN), src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=pgn) as s:
        s.impl.on_can_recv(CAN(identifier=bam_can_id, flags="extended", data=bam_data))
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=dt1_data))
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=dt_wrong))
        assert s.impl.rx_state == 0, "Expected IDLE after SN error, got {}".format(s.impl.rx_state)
        assert s.impl.rx_queue.empty()

test_bam_rx_sn_error()

= BAM receive -- inactivity timeout resets state machine after 10x extension
def test_bam_rx_timeout():
    pgn = 0xFECA
    pgn_bytes = struct.pack("<I", pgn)[:3]
    bam_data = struct.pack("B", TP_CM_BAM) + struct.pack("<H", 9) + struct.pack("B", 2) + b"\xFF" + pgn_bytes
    bam_can_id = _j1939_can_id(7, J1939_TP_CM_PF, J1939_GLOBAL_ADDRESS, 0x80)
    with J1939SoftSocket(TestSocket(CAN), src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=pgn) as s:
        s.impl.tp_dt_timeout = 0.05
        s.impl.on_can_recv(CAN(identifier=bam_can_id, flags="extended", data=bam_data))
        # The timeout extension allows up to 10x tp_dt_timeout before resetting.
        # Wait long enough for the full extension period to expire (10 * 0.05 + buffer).
        time.sleep(0.7)
        assert s.impl.rx_state == 0, "Expected IDLE after timeout, got {}".format(s.impl.rx_state)

test_bam_rx_timeout()


+ J1939SocketImplementation -- BAM transmit

= BAM send of a 9-byte message via TestSocket
def test_bam_tx_9bytes():
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor, J1939SoftSocket(can_sock, src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=0xFECA) as s:
        can_sock.pair(monitor)
        payload = bytes(range(1, 10))
        s.impl.begin_send(payload, 0xFECA, J1939_GLOBAL_ADDRESS)
        pkts = monitor.sniff(count=1, timeout=1)
        assert len(pkts) == 1, "Expected TP.CM_BAM"
        bam = pkts[0]
        assert bam.flags & 0x4, "Expected extended CAN frame"
        _, pf, ps, sa = _j1939_decode_can_id(bam.identifier)
        assert pf == J1939_TP_CM_PF, "PF should be TP.CM"
        assert ps == J1939_GLOBAL_ADDRESS
        assert sa == 0x11
        assert bam.data[0] == TP_CM_BAM
        size = struct.unpack_from("<H", bam.data, 1)[0]
        assert size == 9
        assert bam.data[3] == 2
        pkts = monitor.sniff(count=2, timeout=1)
        assert len(pkts) == 2, "Expected 2 TP.DT frames, got {}".format(len(pkts))
        dt1, dt2 = pkts
        _, pf1, _, _ = _j1939_decode_can_id(dt1.identifier)
        _, pf2, _, _ = _j1939_decode_can_id(dt2.identifier)
        assert pf1 == J1939_TP_DT_PF
        assert pf2 == J1939_TP_DT_PF
        assert dt1.data[0] == 1
        assert dt2.data[0] == 2
        assert dt1.data[1:8] == payload[0:7]
        assert dt2.data[1:3] == payload[7:9]
        assert dt2.data[3:8] == b"\xFF\xFF\xFF\xFF\xFF"

test_bam_tx_9bytes()

= BAM send of a single-frame message (8 bytes or fewer) -- sends direct CAN frame
def test_bam_tx_direct():
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor, J1939SoftSocket(can_sock, src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=0xFECA) as s:
        can_sock.pair(monitor)
        payload = b"\x01\x02\x03\x04\x05"
        s.impl.begin_send(payload, 0xFECA, J1939_GLOBAL_ADDRESS)
        pkts = monitor.sniff(count=1, timeout=1)
        assert len(pkts) == 1, "Expected direct CAN frame"
        pkt = pkts[0]
        assert pkt.flags & 0x4, "Expected extended frame"
        assert pkt.data == payload

test_bam_tx_direct()

= BAM send of a 1785-byte message (max TP size: 255 packets)
def test_bam_tx_1785bytes():
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor, J1939SoftSocket(can_sock, src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=0xFECA) as s:
        can_sock.pair(monitor)
        s.impl.bam_dt_gap = 0.0
        payload = bytes(range(256)) * 6 + bytes(range(249))
        s.impl.begin_send(payload, 0xFECA, J1939_GLOBAL_ADDRESS)
        pkts = monitor.sniff(count=256, timeout=10)
        assert len(pkts) == 256, "Expected 256 CAN frames, got {}".format(len(pkts))
        assert pkts[0].data[0] == TP_CM_BAM
        assert struct.unpack_from("<H", pkts[0].data, 1)[0] == 1785
        assert pkts[0].data[3] == 255
        for i, dt in enumerate(pkts[1:], start=1):
            _, pf, _, _ = _j1939_decode_can_id(dt.identifier)
            assert pf == J1939_TP_DT_PF, "Expected TP.DT at index {}".format(i)
            assert dt.data[0] == i, "Expected SN={}, got {}".format(i, dt.data[0])
        reassembled = b""
        for dt in pkts[1:]:
            reassembled += dt.data[1:]
        assert reassembled[:1785] == payload

test_bam_tx_1785bytes()

= send() queues message and background thread sends it
def test_send_queued():
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor, J1939SoftSocket(can_sock, src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=0xFECA) as s:
        can_sock.pair(monitor)
        s.impl.bam_dt_gap = 0.0
        payload = b"\xDE\xAD\xBE\xEF"
        s.impl.send(payload)
        pkts = monitor.sniff(count=1, timeout=2)
        assert len(pkts) == 1
        assert pkts[0].data == payload

test_send_queued()


+ J1939SocketImplementation -- CMDT (peer-to-peer) transmit/receive

= CMDT receive: RTS -> CTS -> DT -> EndOfMsgACK
def test_cmdt_rx_rts_cts_dt_ack():
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor, J1939SoftSocket(can_sock, src_addr=0x22, dst_addr=0x11, pgn=0xFECA) as s:
        can_sock.pair(monitor)
        pgn = 0xFECA
        pgn_bytes = struct.pack("<I", pgn)[:3]
        rts_data = struct.pack("B", TP_CM_RTS) + struct.pack("<H", 9) + struct.pack("B", 2) + b"\xFF" + pgn_bytes
        rts_can_id = _j1939_can_id(7, J1939_TP_CM_PF, 0x22, 0x11)
        s.impl.on_can_recv(CAN(identifier=rts_can_id, flags="extended", data=rts_data))
        pkts = monitor.sniff(count=1, timeout=1)
        assert len(pkts) == 1, "Expected CTS frame"
        cts = pkts[0]
        _, pf, ps, sa = _j1939_decode_can_id(cts.identifier)
        assert pf == J1939_TP_CM_PF
        assert ps == 0x11
        assert sa == 0x22
        assert cts.data[0] == TP_CM_CTS
        assert cts.data[1] == 2
        assert cts.data[2] == 1
        dt1_data = b"\x01" + b"\x01\x02\x03\x04\x05\x06\x07"
        dt2_data = b"\x02" + b"\x08\x09\xFF\xFF\xFF\xFF\xFF"
        dt_can_id = _j1939_can_id(7, J1939_TP_DT_PF, 0x22, 0x11)
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=dt1_data))
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=dt2_data))
        pkts = monitor.sniff(count=1, timeout=1)
        assert len(pkts) == 1, "Expected EndOfMsgACK"
        eom = pkts[0]
        _, pf, ps, _ = _j1939_decode_can_id(eom.identifier)
        assert pf == J1939_TP_CM_PF
        assert ps == 0x11
        assert eom.data[0] == TP_CM_EndOfMsgACK
        result = s.impl.rx_queue.recv()
        assert result is not None
        msg, ts, rx_pgn, rx_sa, rx_da = result
        assert msg == b"\x01\x02\x03\x04\x05\x06\x07\x08\x09"

test_cmdt_rx_rts_cts_dt_ack()

= CMDT receive with block size: RTS -> CTS (block 1) -> DT * bs -> CTS (block 2) -> DT
def test_cmdt_rx_block_size():
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor, J1939SoftSocket(can_sock, src_addr=0x22, dst_addr=0x11, pgn=0xFECA, bs=2) as s:
        can_sock.pair(monitor)
        pgn = 0xFECA
        pgn_bytes = struct.pack("<I", pgn)[:3]
        total_size = 21
        num_packets = 3
        rts_data = struct.pack("B", TP_CM_RTS) + struct.pack("<H", total_size) + struct.pack("B", num_packets) + b"\xFF" + pgn_bytes
        rts_can_id = _j1939_can_id(7, J1939_TP_CM_PF, 0x22, 0x11)
        dt_can_id = _j1939_can_id(7, J1939_TP_DT_PF, 0x22, 0x11)
        s.impl.on_can_recv(CAN(identifier=rts_can_id, flags="extended", data=rts_data))
        pkts = monitor.sniff(count=1, timeout=1)
        assert pkts[0].data[0] == TP_CM_CTS
        assert pkts[0].data[1] == 2
        assert pkts[0].data[2] == 1
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=b"\x01" + b"\xAA" * 7))
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=b"\x02" + b"\xBB" * 7))
        pkts = monitor.sniff(count=1, timeout=1)
        assert pkts[0].data[0] == TP_CM_CTS
        assert pkts[0].data[1] == 1
        assert pkts[0].data[2] == 3
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=b"\x03" + b"\xCC" * 7))
        pkts = monitor.sniff(count=1, timeout=1)
        assert pkts[0].data[0] == TP_CM_EndOfMsgACK
        result = s.impl.rx_queue.recv()
        assert result is not None
        msg, _, rx_pgn, rx_sa, rx_da = result
        assert msg == b"\xAA" * 7 + b"\xBB" * 7 + b"\xCC" * 7

test_cmdt_rx_block_size()

= CMDT transmit: RTS from us -> CTS from peer -> DT -> EndOfMsgACK
def test_cmdt_tx():
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor, J1939SoftSocket(can_sock, src_addr=0x11, dst_addr=0x22, pgn=0xFECA) as s:
        can_sock.pair(monitor)
        s.impl.tp_cm_timeout = 2.0
        payload = bytes(range(1, 10))
        s.impl.begin_send(payload, 0xFECA, 0x22)
        pkts = monitor.sniff(count=1, timeout=1)
        assert len(pkts) == 1, "Expected TP.CM_RTS"
        rts = pkts[0]
        _, pf, ps, sa = _j1939_decode_can_id(rts.identifier)
        assert pf == J1939_TP_CM_PF
        assert ps == 0x22
        assert sa == 0x11
        assert rts.data[0] == TP_CM_RTS
        assert struct.unpack_from("<H", rts.data, 1)[0] == 9
        assert rts.data[3] == 2
        pgn_bytes = struct.pack("<I", 0xFECA)[:3]
        cts_data = struct.pack("B", TP_CM_CTS) + struct.pack("B", 2) + struct.pack("B", 1) + b"\xFF\xFF" + pgn_bytes
        cts_can_id = _j1939_can_id(7, J1939_TP_CM_PF, 0x11, 0x22)
        s.impl.on_can_recv(CAN(identifier=cts_can_id, flags="extended", data=cts_data))
        pkts = monitor.sniff(count=2, timeout=2)
        assert len(pkts) == 2, "Expected 2 TP.DT frames, got {}".format(len(pkts))
        dt1, dt2 = pkts
        _, pf1, ps1, _ = _j1939_decode_can_id(dt1.identifier)
        assert pf1 == J1939_TP_DT_PF
        assert ps1 == 0x22
        assert dt1.data[0] == 1
        assert dt1.data[1:8] == payload[0:7]
        assert dt2.data[0] == 2
        eom_data = struct.pack("B", TP_CM_EndOfMsgACK) + struct.pack("<H", 9) + struct.pack("B", 2) + b"\xFF" + pgn_bytes
        eom_can_id = _j1939_can_id(7, J1939_TP_CM_PF, 0x11, 0x22)
        s.impl.on_can_recv(CAN(identifier=eom_can_id, flags="extended", data=eom_data))
        time.sleep(0.1)
        assert s.impl.tx_state == 0, "Expected TX IDLE after ACK"

test_cmdt_tx()

= CMDT receive -- listen_only does not send CTS or EndOfMsgACK
def test_cmdt_rx_listen_only():
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor, J1939SoftSocket(can_sock, src_addr=0x22, dst_addr=0x11, pgn=0xFECA, listen_only=True) as s:
        can_sock.pair(monitor)
        pgn = 0xFECA
        pgn_bytes = struct.pack("<I", pgn)[:3]
        rts_data = struct.pack("B", TP_CM_RTS) + struct.pack("<H", 9) + struct.pack("B", 2) + b"\xFF" + pgn_bytes
        rts_can_id = _j1939_can_id(7, J1939_TP_CM_PF, 0x22, 0x11)
        s.impl.on_can_recv(CAN(identifier=rts_can_id, flags="extended", data=rts_data))
        pkts = monitor.sniff(count=1, timeout=0.2)
        assert len(pkts) == 0, "listen_only: expected no CTS"
        dt_can_id = _j1939_can_id(7, J1939_TP_DT_PF, 0x22, 0x11)
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=b"\x01" + b"\x01\x02\x03\x04\x05\x06\x07"))
        s.impl.on_can_recv(CAN(identifier=dt_can_id, flags="extended", data=b"\x02" + b"\x08\x09\xFF\xFF\xFF\xFF\xFF"))
        pkts = monitor.sniff(count=1, timeout=0.2)
        assert len(pkts) == 0, "listen_only: expected no EndOfMsgACK"
        result = s.impl.rx_queue.recv()
        assert result is not None
        msg, _, rx_pgn, rx_sa, rx_da = result
        assert msg == b"\x01\x02\x03\x04\x05\x06\x07\x08\x09"

test_cmdt_rx_listen_only()

= Single-frame receive: actual PGN propagated through rx_queue (not socket filter)
def test_sf_pgn_propagation():
    """When rx_pgn=0 (accept all), the received PGN must reflect the actual
    CAN frame, not the socket's filter value."""
    from scapy.contrib.automotive.j1939.j1939_soft_socket import _j1939_can_id, _pgn_from_can_id
    pgn_a = 0xFECA  # PDU2 (PF=0xFE, GE=0xCA)
    pgn_b = 0xF004  # PDU2 (PF=0xF0, GE=0x04)
    can_id_a = _j1939_can_id(6, 0xFE, 0xCA, 0x33)  # SA=0x33
    can_id_b = _j1939_can_id(6, 0xF0, 0x04, 0x44)  # SA=0x44
    with J1939SoftSocket(TestSocket(CAN), src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=0) as s:
        s.impl.on_can_recv(CAN(identifier=can_id_a, flags="extended", data=b"\x01\x02\x03"))
        s.impl.on_can_recv(CAN(identifier=can_id_b, flags="extended", data=b"\x04\x05\x06"))
        result_a = s.impl.rx_queue.recv()
        assert result_a is not None
        msg_a, _, pgn_a_rx, sa_a, da_a = result_a
        assert pgn_a_rx == 0xFECA, "Expected PGN 0xFECA, got 0x{:05X}".format(pgn_a_rx)
        assert sa_a == 0x33, "Expected SA 0x33, got 0x{:02X}".format(sa_a)
        assert da_a == J1939_GLOBAL_ADDRESS, "PDU2 DA should be broadcast"
        result_b = s.impl.rx_queue.recv()
        assert result_b is not None
        msg_b, _, pgn_b_rx, sa_b, da_b = result_b
        assert pgn_b_rx == 0xF004, "Expected PGN 0xF004, got 0x{:05X}".format(pgn_b_rx)
        assert sa_b == 0x44, "Expected SA 0x44, got 0x{:02X}".format(sa_b)

test_sf_pgn_propagation()

= End-to-end: recv() returns actual PGN, SA, DA for single-frame messages
def test_e2e_recv_pgn():
    """Verify that J1939SoftSocket.recv() propagates the actual PGN and
    addressing from the CAN frame, not the socket's fixed configuration."""
    pgn_val = 0xFECA
    can_id = _j1939_can_id(6, 0xFE, 0xCA, 0x33)
    with J1939SoftSocket(TestSocket(CAN), src_addr=0x11, dst_addr=J1939_GLOBAL_ADDRESS, pgn=0) as s:
        s.impl.on_can_recv(CAN(identifier=can_id, flags="extended", data=b"\xDE\xAD"))
        pkt = s.recv()
        assert pkt is not None
        assert pkt.pgn == 0xFECA, "recv() PGN should be 0xFECA, got 0x{:05X}".format(pkt.pgn)
        assert pkt.src_addr == 0x33, "recv() src_addr should be 0x33, got 0x{:02X}".format(pkt.src_addr)
        assert pkt.dst_addr == J1939_GLOBAL_ADDRESS

test_e2e_recv_pgn()


