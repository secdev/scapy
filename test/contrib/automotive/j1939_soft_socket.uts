+ J1939-81 Address Claiming

= Address claiming constants are correct
assert PGN_ADDRESS_CLAIMED == 0xEE00, "PGN_ADDRESS_CLAIMED should be 0xEE00"
assert PGN_REQUEST == 0xEA00, "PGN_REQUEST should be 0xEA00"
assert J1939_NULL_ADDRESS == 0xFE, "J1939_NULL_ADDRESS should be 0xFE"
assert J1939_ADDR_STATE_UNCLAIMED == 0
assert J1939_ADDR_STATE_CLAIMING == 1
assert J1939_ADDR_STATE_CLAIMED == 2
assert J1939_ADDR_STATE_CANNOT_CLAIM == 3

= Test 1: 64-bit NAME serialization (pack and unpack)
for name_val in [0x0000000000000001, 0xFFFFFFFFFFFFFFFF, 0x0102030405060708, 0]:
    packed = struct.pack("<Q", name_val)
    assert len(packed) == 8, "NAME must be exactly 8 bytes"
    unpacked = struct.unpack("<Q", packed)[0]
    assert unpacked == name_val, "Round-trip failed for NAME=0x{:016X}".format(name_val)

= Test 2: Initial Address Claim Broadcast
def test_address_claim_initial_broadcast():
    my_name = 0x0000000000000001
    my_addr = 0x80
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor:
        can_sock.pair(monitor)
        with J1939SoftSocket(can_sock, src_addr=my_addr, pgn=0xFECA, name=my_name) as s:
            # Address Claimed frame should be sent synchronously in __init__
            pkt = monitor.recv()
            assert pkt is not None, "No Address Claimed frame broadcast on init"
            assert pkt.flags & 0x4, "Frame must be extended (29-bit) CAN"
            _, pf, ps, sa = _j1939_decode_can_id(pkt.identifier)
            assert pf == J1939_PF_ADDRESS_CLAIMED, \
                "Expected PF=0x{:02X} (Address Claimed), got 0x{:02X}".format(
                    J1939_PF_ADDRESS_CLAIMED, pf)
            assert ps == J1939_GLOBAL_ADDRESS, \
                "Expected DA=0xFF (broadcast), got 0x{:02X}".format(ps)
            assert sa == my_addr, \
                "Expected SA=0x{:02X}, got 0x{:02X}".format(my_addr, sa)
            assert len(pkt.data) == 8, "NAME payload must be 8 bytes"
            assert struct.unpack("<Q", bytes(pkt.data)[:8])[0] == my_name, \
                "NAME payload mismatch"
            assert s.impl.address_state == J1939_ADDR_STATE_CLAIMING, \
                "Expected CLAIMING state on init"

test_address_claim_initial_broadcast()

= Test 3: 250ms Blocking State
def test_address_claim_blocking_send():
    my_name = 0x0000000000000001
    with TestSocket(CAN) as can_sock:
        with J1939SoftSocket(can_sock, src_addr=0x80, pgn=0xFECA, name=my_name) as s:
            assert s.impl.address_state == J1939_ADDR_STATE_CLAIMING, \
                "Expected CLAIMING state immediately after init"
            try:
                s.impl.send(b'\x01\x02\x03')
                assert False, "Expected Scapy_Exception was not raised"
            except Scapy_Exception as e:
                assert "address" in str(e).lower() or "claim" in str(e).lower(), \
                    "Exception message should mention address or claim: {}".format(e)

test_address_claim_blocking_send()

= Test 4: Winning Arbitration (our NAME is lower — we win)
def test_address_claim_win_arbitration():
    my_name = 0x0000000000000001    # lower = higher priority
    their_name = 0x0000000000000002  # higher = lower priority
    my_addr = 0x80
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor:
        can_sock.pair(monitor)
        with J1939SoftSocket(can_sock, src_addr=my_addr, pgn=0xFECA, name=my_name) as s:
            # Consume the initial Address Claimed frame
            _ = monitor.recv()
            # Inject a conflicting Address Claimed from another node at
            # our address with a HIGHER NAME (they lose, we win)
            conflict_id = _j1939_can_id(6, J1939_PF_ADDRESS_CLAIMED,
                                        J1939_GLOBAL_ADDRESS, my_addr)
            conflict_frame = CAN(identifier=conflict_id, flags="extended",
                                 data=struct.pack("<Q", their_name))
            s.impl.on_can_recv(conflict_frame)
            # We should re-broadcast our Address Claimed to defend the address
            pkt = monitor.recv()
            assert pkt is not None, "Expected re-broadcast of Address Claimed"
            _, pf, ps, sa = _j1939_decode_can_id(pkt.identifier)
            assert pf == J1939_PF_ADDRESS_CLAIMED, \
                "Re-broadcast must be an Address Claimed frame"
            assert sa == my_addr, "Re-broadcast must use our SA"
            assert ps == J1939_GLOBAL_ADDRESS, "Re-broadcast must be to global address"
            # Address state should still be CLAIMING (250ms window not expired)
            assert s.impl.address_state == J1939_ADDR_STATE_CLAIMING, \
                "Expected CLAIMING state after winning arbitration"

test_address_claim_win_arbitration()

= Test 5: Losing Arbitration (our NAME is higher — we lose)
def test_address_claim_lose_arbitration():
    my_name = 0x0000000000000002    # higher = lower priority
    their_name = 0x0000000000000001  # lower = higher priority
    my_addr = 0x80
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor:
        can_sock.pair(monitor)
        with J1939SoftSocket(can_sock, src_addr=my_addr, pgn=0xFECA, name=my_name) as s:
            # Consume the initial Address Claimed frame
            _ = monitor.recv()
            # Inject a conflicting Address Claimed from another node at
            # our address with a LOWER NAME (they win, we lose)
            conflict_id = _j1939_can_id(6, J1939_PF_ADDRESS_CLAIMED,
                                        J1939_GLOBAL_ADDRESS, my_addr)
            conflict_frame = CAN(identifier=conflict_id, flags="extended",
                                 data=struct.pack("<Q", their_name))
            s.impl.on_can_recv(conflict_frame)
            # We lose: should broadcast Cannot Claim from SA=0xFE
            pkt = monitor.recv()
            assert pkt is not None, "Expected Cannot Claim message"
            _, pf, ps, sa = _j1939_decode_can_id(pkt.identifier)
            assert pf == J1939_PF_ADDRESS_CLAIMED, \
                "Cannot Claim must use PGN 0xEE00"
            assert sa == J1939_NULL_ADDRESS, \
                "Cannot Claim must use SA=0xFE (null address), got SA=0x{:02X}".format(sa)
            assert ps == J1939_GLOBAL_ADDRESS, \
                "Cannot Claim must be to global address"
            assert struct.unpack("<Q", bytes(pkt.data)[:8])[0] == my_name, \
                "Cannot Claim must carry our NAME"
            assert s.impl.address_state == J1939_ADDR_STATE_CANNOT_CLAIM, \
                "Expected CANNOT_CLAIM state after losing arbitration"

test_address_claim_lose_arbitration()

= Test 6: Request Response -- CLAIMED socket responds with Address Claimed
def test_address_claim_request_response():
    my_name = 0x0000000000000001
    my_addr = 0x80
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor:
        can_sock.pair(monitor)
        with J1939SoftSocket(can_sock, src_addr=my_addr, pgn=0xFECA, name=my_name) as s:
            # Consume the initial Address Claimed frame
            _ = monitor.recv()
            # Manually transition to CLAIMED state (skip the 250ms wait)
            s.impl.address_state = J1939_ADDR_STATE_CLAIMED
            # Inject a Request for PGN_ADDRESS_CLAIMED broadcast to global address
            req_pgn_bytes = struct.pack("<I", PGN_ADDRESS_CLAIMED)[:3]
            req_id = _j1939_can_id(6, J1939_PF_REQUEST,
                                   J1939_GLOBAL_ADDRESS, 0x20)
            req_frame = CAN(identifier=req_id, flags="extended",
                            data=req_pgn_bytes + b'\xFF\xFF\xFF\xFF\xFF')
            s.impl.on_can_recv(req_frame)
            # Should respond with an Address Claimed broadcast
            pkt = monitor.recv()
            assert pkt is not None, "Expected Address Claimed response to Request"
            _, pf, ps, sa = _j1939_decode_can_id(pkt.identifier)
            assert pf == J1939_PF_ADDRESS_CLAIMED, \
                "Response must be an Address Claimed frame"
            assert sa == my_addr, "Response must use our claimed SA"
            assert ps == J1939_GLOBAL_ADDRESS, "Response must be broadcast"
            assert struct.unpack("<Q", bytes(pkt.data)[:8])[0] == my_name, \
                "Response must carry our NAME"

test_address_claim_request_response()

= Test: cannot-claim socket responds to Request with Cannot Claim
def test_address_claim_cannot_claim_request_response():
    my_name = 0x0000000000000001
    my_addr = 0x80
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor:
        can_sock.pair(monitor)
        with J1939SoftSocket(can_sock, src_addr=my_addr, pgn=0xFECA, name=my_name) as s:
            # Consume the initial Address Claimed frame
            _ = monitor.recv()
            # Manually force CANNOT_CLAIM state
            s.impl.address_state = J1939_ADDR_STATE_CANNOT_CLAIM
            # Inject a Request for PGN_ADDRESS_CLAIMED
            req_pgn_bytes = struct.pack("<I", PGN_ADDRESS_CLAIMED)[:3]
            req_id = _j1939_can_id(6, J1939_PF_REQUEST, J1939_GLOBAL_ADDRESS, 0x20)
            req_frame = CAN(identifier=req_id, flags="extended",
                            data=req_pgn_bytes + b'\xFF\xFF\xFF\xFF\xFF')
            s.impl.on_can_recv(req_frame)
            # Should respond with a Cannot Claim (SA=0xFE)
            pkt = monitor.recv()
            assert pkt is not None, "Expected Cannot Claim response to Request"
            _, pf, ps, sa = _j1939_decode_can_id(pkt.identifier)
            assert pf == J1939_PF_ADDRESS_CLAIMED
            assert sa == J1939_NULL_ADDRESS, \
                "Cannot Claim response must use SA=0xFE, got 0x{:02X}".format(sa)

test_address_claim_cannot_claim_request_response()

= Test: 250ms timer transitions state from CLAIMING to CLAIMED
def test_address_claim_timer_transition():
    my_name = 0x0000000000000001
    my_addr = 0x80
    with TestSocket(CAN) as can_sock:
        with J1939SoftSocket(can_sock, src_addr=my_addr, pgn=0xFECA, name=my_name) as s:
            assert s.impl.address_state == J1939_ADDR_STATE_CLAIMING
            # Wait for the 250ms claiming window to expire
            time.sleep(J1939_ADDR_CLAIM_TIMEOUT + 0.1)
            assert s.impl.address_state == J1939_ADDR_STATE_CLAIMED, \
                "Expected CLAIMED after 250ms, got state={}".format(
                    s.impl.address_state)

test_address_claim_timer_transition()

= Test: socket without name has UNCLAIMED state and sends freely
def test_no_address_claim_unclaimed():
    with TestSocket(CAN) as can_sock:
        with J1939SoftSocket(can_sock, src_addr=0x11, pgn=0xFECA) as s:
            assert s.impl.address_state == J1939_ADDR_STATE_UNCLAIMED, \
                "Socket without name should be UNCLAIMED"
            # send() should not raise when name is None
            s.impl.send(b'\x01\x02\x03\x04\x05\x06\x07\x08')

test_no_address_claim_unclaimed()

= Test: CANNOT_CLAIM socket blocks application sends
def test_address_claim_cannot_claim_blocks_send():
    my_name = 0x0000000000000001
    with TestSocket(CAN) as can_sock:
        with J1939SoftSocket(can_sock, src_addr=0x80, pgn=0xFECA, name=my_name) as s:
            s.impl.address_state = J1939_ADDR_STATE_CANNOT_CLAIM
            try:
                s.impl.send(b'\x01\x02\x03')
                assert False, "Expected Scapy_Exception was not raised for CANNOT_CLAIM"
            except Scapy_Exception:
                pass

test_address_claim_cannot_claim_blocks_send()

= Test: address claiming ignored when name is not set
def test_address_claim_ignored_without_name():
    # Even if address claimed / request frames arrive, they should not crash
    # and should not alter the address_state (which stays UNCLAIMED)
    with TestSocket(CAN) as can_sock:
        with J1939SoftSocket(can_sock, src_addr=0x80, pgn=0) as s:
            assert s.impl.name is None
            claim_id = _j1939_can_id(6, J1939_PF_ADDRESS_CLAIMED, J1939_GLOBAL_ADDRESS, 0x80)
            claim_frame = CAN(identifier=claim_id, flags="extended",
                              data=struct.pack("<Q", 0x0000000000000001))
            s.impl.on_can_recv(claim_frame)
            assert s.impl.address_state == J1939_ADDR_STATE_UNCLAIMED

test_address_claim_ignored_without_name()

= Test: _on_tp_cm short data
def test_tp_cm_short_data():
    with TestSocket(CAN) as can_sock:
        with J1939SoftSocket(can_sock, src_addr=0x22, dst_addr=0x11, pgn=0) as s:
            cm_id = _j1939_can_id(7, J1939_TP_CM_PF, 0x22, 0x11)
            s.impl.on_can_recv(CAN(identifier=cm_id, flags="extended", data=b'\x20\x00'))
            assert s.impl.rx_queue.empty(), "Short TP.CM should be dropped"
    cleanup_testsockets()

test_tp_cm_short_data()

= Test: _send_abort sends correct abort frame
def test_send_abort_frame():
    with TestSocket(CAN) as can_sock, TestSocket(CAN) as monitor:
        can_sock.pair(monitor)
        with J1939SoftSocket(can_sock, src_addr=0x22, dst_addr=0xFF, pgn=0) as s:
            s.impl.address_state = J1939_ADDR_STATE_CLAIMED
            s.impl._send_abort(0x11, 0xFECA, 0x01)
            pkts = monitor.sniff(count=1, timeout=1)
            assert len(pkts) == 1, "Expected abort frame"
            _, pf, ps, sa = _j1939_decode_can_id(pkts[0].identifier)
            assert pf == J1939_TP_CM_PF
            assert ps == 0x11
            assert sa == 0x22
            assert pkts[0].data[0] == TP_Conn_Abort
            assert pkts[0].data[1] == 0x01
    cleanup_testsockets()

test_send_abort_frame()

= Test: on_can_recv ignores non-extended frames
def test_non_extended_frame_ignored():
    with TestSocket(CAN) as can_sock:
        with J1939SoftSocket(can_sock, src_addr=0x22, dst_addr=0xFF, pgn=0) as s:
            s.impl.on_can_recv(CAN(identifier=0x123, flags=0, data=b'\x01\x02\x03'))
            assert s.impl.rx_queue.empty(), "Non-extended frames should be ignored"
    cleanup_testsockets()

test_non_extended_frame_ignored()

= Test: _on_request_pgn with short data
def test_request_pgn_short_data():
    with TestSocket(CAN) as can_sock:
        with J1939SoftSocket(can_sock, src_addr=0x80, pgn=0) as s:
            req_id = _j1939_can_id(6, J1939_PF_REQUEST, 0x80, 0x10)
            s.impl.on_can_recv(CAN(identifier=req_id, flags="extended", data=b'\x01\x02'))
            # Should not crash; short data ignored
    cleanup_testsockets()

test_request_pgn_short_data()

= Test: close() is idempotent
def test_close_idempotent():
    with TestSocket(CAN) as can_sock:
        s = J1939SoftSocket(can_sock, src_addr=0x10, pgn=0)
        s.close()
        assert s.closed
        s.close()
        assert s.closed
    cleanup_testsockets()

test_close_idempotent()

= Test: recv_raw returns None when socket is closed
def test_recv_raw_closed():
    with TestSocket(CAN) as can_sock:
        s = J1939SoftSocket(can_sock, src_addr=0x10, pgn=0)
        s.close()
        cls, data, ts = s.recv_raw()
        assert data is None
        assert ts is None
    cleanup_testsockets()

test_recv_raw_closed()

= Test: recv returns None when queue is empty
def test_recv_no_data():
    with TestSocket(CAN) as can_sock:
        with J1939SoftSocket(can_sock, src_addr=0x10, pgn=0) as s:
            assert s.impl.rx_queue.empty()
    cleanup_testsockets()

test_recv_no_data()


+ J1939SoftSocket Extra Coverage

= J1939SoftSocket.recv stashes metadata even for unknown packet types
class DummyPacket(Packet):
    pass

with J1939SoftSocket(TestSocket(CAN), basecls=DummyPacket) as s:
    s.impl.rx_queue.send((b"data", 1.23, 0xFECA, 0x11, 0xFF))
    pkt = s.recv()
    assert isinstance(pkt, DummyPacket)
    assert s._last_rx_pgn == 0xFECA

= TimeoutScheduler.cancel raises Scapy_Exception for unknown handle
try:
    TimeoutScheduler.cancel("not a handle")
    assert False, "Expected Scapy_Exception"
except Scapy_Exception:
    pass

= TimeoutScheduler.Handle.cancel raises Scapy_Exception if already cancelled
h = TimeoutScheduler.schedule(10, lambda: None)
h.cancel()
try:
    h.cancel()
    assert False, "Expected Scapy_Exception"
except Scapy_Exception:
    pass

= _on_address_claimed edge cases
with J1939SoftSocket(TestSocket(CAN), src_addr=0x11, name=1) as s:
    # len(data) < 8
    s.impl._on_address_claimed(b"\x00"*7, 0x11, 0xFF)
    # sa == J1939_NULL_ADDRESS
    s.impl._on_address_claimed(b"\x00"*8, J1939_NULL_ADDRESS, 0xFF)
    # received_name == self.name (emits warning)
    s.impl._on_address_claimed(struct.pack("<Q", 1), 0x11, 0xFF)

= _on_request_pgn edge cases
with J1939SoftSocket(TestSocket(CAN), src_addr=0x11, name=1) as s:
    # len(data) < 3
    s.impl._on_request_pgn(b"\x00"*2, 0x11, 0xFF)
    # requested_pgn != PGN_ADDRESS_CLAIMED
    s.impl._on_request_pgn(b"\x00\x00\x00", 0x11, 0xFF)

= TP receive BAM edge cases
with J1939SoftSocket(TestSocket(CAN), src_addr=0x11) as s:
    pgn_bytes = struct.pack("<I", 0xFECA)[:3]
    # _recv_bam with invalid total_size
    s.impl._on_tp_cm(struct.pack("B", TP_CM_BAM) + struct.pack("<H", 8) + struct.pack("B", 1) + b"\xFF" + pgn_bytes, 0x80, 0xFF, 0)
    assert s.impl.rx_state == 0

= TP receive RTS edge cases
with J1939SoftSocket(TestSocket(CAN), src_addr=0x11) as s:
    pgn_bytes = struct.pack("<I", 0xFECA)[:3]
    # _recv_rts with wrong DA
    s.impl._on_tp_cm(struct.pack("B", TP_CM_RTS) + struct.pack("<H", 9) + struct.pack("B", 2) + b"\xFF" + pgn_bytes, 0x80, 0x22, 0)
    assert s.impl.rx_state == 0

= TP receive CTS edge cases
with J1939SoftSocket(TestSocket(CAN), src_addr=0x11) as s:
    pgn_bytes = struct.pack("<I", 0xFECA)[:3]
    # _recv_cts with wrong state
    s.impl._on_tp_cm(struct.pack("B", TP_CM_CTS) + struct.pack("BB", 1, 1) + b"\xFF\xFF" + pgn_bytes, 0x80, 0x11, 0)
    # _recv_cts with packets_to_send == 0 (Hold)
    s.impl.tx_state = 2 # J1939_TX_CMDT_WAIT_CTS
    s.impl.tx_pgn = 0xFECA
    s.impl._on_tp_cm(struct.pack("B", TP_CM_CTS) + struct.pack("BB", 0, 1) + b"\xFF\xFF" + pgn_bytes, 0x80, 0x11, 0)
    assert s.impl.tx_state == 2

= TP receive EOM edge cases
with J1939SoftSocket(TestSocket(CAN), src_addr=0x11) as s:
    pgn_bytes = struct.pack("<I", 0xFECA)[:3]
    # _recv_eom_ack with wrong PGN
    s.impl.tx_state = 4 # J1939_TX_CMDT_WAIT_ACK
    s.impl.tx_pgn = 0xFECA
    wrong_pgn_bytes = struct.pack("<I", 0xFECB)[:3]
    s.impl._on_tp_cm(struct.pack("B", TP_CM_EndOfMsgACK) + struct.pack("<H", 9) + struct.pack("B", 2) + b"\xFF" + wrong_pgn_bytes, 0x80, 0x11, 0)
    assert s.impl.tx_state == 4

= TP receive Abort edge cases
with J1939SoftSocket(TestSocket(CAN), src_addr=0x11) as s:
    # _recv_abort with len(data) == 1
    s.impl._on_tp_cm(struct.pack("B", TP_Conn_Abort), 0x80, 0x11, 0)
    assert s.impl.tx_state == 0

= _on_tp_dt edge cases
with J1939SoftSocket(TestSocket(CAN), src_addr=0x11) as s:
    s.impl.rx_state = 1 # J1939_RX_BAM_WAIT_DATA
    s.impl.rx_src_addr = 0x80
    # wrong SA
    s.impl._on_tp_dt(b"\x01\xAA", 0x81, 0x11)
    # short data
    s.impl._on_tp_dt(b"", 0x80, 0x11)

= begin_send edge cases
with J1939SoftSocket(TestSocket(CAN), src_addr=0x11) as s:
    # length > J1939_TP_MAX_DLEN
    s.impl.begin_send(b"A" * 2000, 0xFECA, 0xFF)
    # tx_state != J1939_TX_IDLE
    s.impl.tx_state = 1
    s.impl.begin_send(b"A" * 10, 0xFECA, 0xFF)

= on_can_recv edge cases
with J1939SoftSocket(TestSocket(CAN), src_addr=0x11, pgn=0xFECA) as s:
    # unexpected PGN (emits warning once)
    s.impl.on_can_recv(CAN(identifier=_j1939_can_id(6, 0xFE, 0xCB, 0x80), flags="extended", data=b"\x00"))
    assert s.impl.filter_warning_emitted
    # DA mismatch (PDU1)
    s.impl.on_can_recv(CAN(identifier=_j1939_can_id(6, 0x01, 0x22, 0x80), flags="extended", data=b"\x00"))


= Delete test sockets
cleanup_testsockets()
_ts = TimeoutScheduler._thread
TimeoutScheduler.clear()
if _ts is not None:
    _ts.join(timeout=5)

log_runtime.removeHandler(handler)
