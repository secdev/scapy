+ DM PGN constants

= J1939_DM_PGNS contains all standard DM entries
assert len(J1939_DM_PGNS) == 57
for name in ("DM1", "DM2", "DM3", "DM4", "DM5", "DM6", "DM11", "DM12"):
    assert name in J1939_DM_PGNS, "Missing {}".format(name)

= DM PGN values are correct (spot-check DM1 and DM6)
assert J1939_DM_PGNS["DM1"] == 0xFECA, "DM1 PGN: 0x{:04X}".format(J1939_DM_PGNS["DM1"])
assert J1939_DM_PGNS["DM6"] == 0xFECF, "DM6 PGN: 0x{:04X}".format(J1939_DM_PGNS["DM6"])

= PDU2 DM PGNs have PF byte >= 0xF0
for name, pgn in J1939_DM_PGNS.items():
    pf = (pgn >> 8) & 0xFF
    if pf >= 0xF0:
        assert pf >= 0xF0, "{} PF=0x{:02X} should be PDU2".format(name, pf)

= J1939_PF_ACK and PGN_ACK have correct values
assert J1939_PF_ACK == 0xE8, "J1939_PF_ACK: 0x{:02X}".format(J1939_PF_ACK)
assert PGN_ACK == 0xE800, "PGN_ACK: 0x{:04X}".format(PGN_ACK)

= _pgn_matches: PDU2 positive match
# DM1: PF=0xFE, PS=0xCA -> PGN = 0xFECA
assert _pgn_matches(0xFE, 0xCA, 0xFECA), "PDU2 match should succeed"

= _pgn_matches: PDU2 mismatch (wrong PS)
assert not _pgn_matches(0xFE, 0xCB, 0xFECA), "Different PS should not match"

= _pgn_matches: PDU1 positive match (PF < 0xF0, low byte of PGN is 0x00)
# ACK: PF=0xE8, PS=DA (not part of PGN), PGN=0xE800
assert _pgn_matches(0xE8, 0x00, 0xE800), "PDU1 match should succeed"

= _pgn_matches: PDU1 mismatch (different PF)
assert not _pgn_matches(0xE9, 0x00, 0xE800), "Different PDU1 PF should not match"


+ DmScanResult class

= DmScanResult: supported result sets correct attributes
res = DmScanResult("DM1", 0xFECA, True)
assert res.dm_name == "DM1"
assert res.pgn == 0xFECA
assert res.supported is True
assert res.packet is None
assert res.error is None

= DmScanResult: NACK result sets correct attributes
res = DmScanResult("DM2", 0xFECB, False, error="NACK")
assert res.supported is False
assert res.error == "NACK"

= DmScanResult: Timeout result
res = DmScanResult("DM5", 0xFECE, False, error="Timeout")
assert res.supported is False
assert res.error == "Timeout"
assert res.packet is None

= DmScanResult: __repr__ contains dm_name and pgn
res = DmScanResult("DM1", 0xFECA, True)
r = repr(res)
assert "DM1" in r, "repr should contain dm_name"
assert "FECA" in r.upper(), "repr should contain pgn"


+ j1939_scan_dm_pgn - probe frame format

= dm_pgn_probe: sends a unicast Request frame to target_da
def test_dm_pgn_probe_frame():
    with TestSocket(CAN) as tx_sock, TestSocket(CAN) as monitor:
        tx_sock.pair(monitor)
        j1939_scan_dm_pgn(tx_sock, target_da=0x00, pgn=J1939_DM_PGNS["DM1"],
                          dm_name="DM1", sniff_time=0.0)
        pkts = monitor.sniff(count=1, timeout=0.2)
        assert len(pkts) == 1, "Expected 1 probe frame, got {}".format(len(pkts))
        probe = pkts[0]
        _, pf, ps, sa = _j1939_decode_can_id(probe.identifier)
        assert probe.flags & 0x4, "Expected extended CAN frame"
        assert pf == J1939_PF_REQUEST, "PF should be 0xEA (Request)"
        assert ps == 0x00, "DA should be target_da=0x00"
        assert sa == 0xF9, "SA should be 0xF9 (diag adapter)"
        expected_payload = struct.pack("<I", J1939_DM_PGNS["DM1"])[:3]
        assert bytes(probe.data) == expected_payload, \
            "Payload should be LE PGN, got {}".format(bytes(probe.data).hex())
    cleanup_testsockets()

test_dm_pgn_probe_frame()

= dm_pgn_probe: payload encodes the requested PGN in little-endian
def test_dm_pgn_probe_payload_le():
    with TestSocket(CAN) as tx_sock, TestSocket(CAN) as monitor:
        tx_sock.pair(monitor)
        j1939_scan_dm_pgn(tx_sock, target_da=0x10, pgn=J1939_DM_PGNS["DM6"],
                          dm_name="DM6", sniff_time=0.0)
        pkts = monitor.sniff(count=1, timeout=0.2)
        assert len(pkts) == 1
        payload = bytes(pkts[0].data)
        # DM6 = 0xFECF = 65231; LE 3 bytes: CF FE 00
        assert payload == b'\xcf\xfe\x00', \
            "DM6 LE payload should be CF FE 00, got {}".format(payload.hex())
    cleanup_testsockets()

test_dm_pgn_probe_payload_le()


+ j1939_scan_dm_pgn - response classification

= dm_pgn_probe: positive response (ECU replies with requested PGN)
sock = TestSocket(CAN)
# Inject a DM1 response from SA=0x10 (PDU2: PF=0xFE, PS=0xCA)
resp_can_id = _j1939_can_id(6, 0xFE, 0xCA, 0x10)
sock.ins.send(bytes(CAN(identifier=resp_can_id, flags="extended",
                        data=b'\xff\xff' + b'\x00' * 6)))
res = j1939_scan_dm_pgn(sock, target_da=0x10, pgn=J1939_DM_PGNS["DM1"],
                        dm_name="DM1", sniff_time=0.1)
assert res.supported is True, "ECU DM1 reply should be detected as supported"
assert res.error is None
assert res.packet is not None
cleanup_testsockets()

= dm_pgn_probe: NACK response (ECU replies with PGN 0xE800, ctrl=0x01)
sock = TestSocket(CAN)
# NACK from SA=0x20, directed to our src_addr=0xF9 (PDU1: PF=0xE8, PS=src_addr)
nack_can_id = _j1939_can_id(6, J1939_PF_ACK, 0xF9, 0x20)
# NACK payload: ctrl=0x01, group_fn=0xFF, reserved=0xFF, pgn LE (3 bytes), padding
nack_pgn_le = struct.pack("<I", J1939_DM_PGNS["DM2"])[:3]
nack_data = b'\x01\xff\xff' + nack_pgn_le + b'\xff\xff'
sock.ins.send(bytes(CAN(identifier=nack_can_id, flags="extended",
                        data=nack_data)))
res = j1939_scan_dm_pgn(sock, target_da=0x20, pgn=J1939_DM_PGNS["DM2"],
                        dm_name="DM2", sniff_time=0.1)
assert res.supported is False, "NACK should mark PGN as not supported"
assert res.error == "NACK"
assert res.packet is not None
cleanup_testsockets()

= dm_pgn_probe: timeout (no response within sniff_time)
sock = TestSocket(CAN)
res = j1939_scan_dm_pgn(sock, target_da=0x30, pgn=J1939_DM_PGNS["DM5"],
                        dm_name="DM5", sniff_time=0.05)
assert res.supported is False
assert res.error == "Timeout"
assert res.packet is None
cleanup_testsockets()

= dm_pgn_probe: non-extended (11-bit) frames are ignored
sock = TestSocket(CAN)
# 11-bit frame - flags has no extended bit
sock.ins.send(bytes(CAN(identifier=0x040, data=b'\xca\xfe\x00\x00\x00\x00\x00\x00')))
res = j1939_scan_dm_pgn(sock, target_da=0x40, pgn=J1939_DM_PGNS["DM1"],
                        dm_name="DM1", sniff_time=0.1)
assert res.supported is False
assert res.error == "Timeout", "Non-extended frames must be ignored"
cleanup_testsockets()

= dm_pgn_probe: response from wrong SA is ignored
sock = TestSocket(CAN)
# Response from SA=0x55 when we probed DA=0x30
resp_can_id = _j1939_can_id(6, 0xFE, 0xCA, 0x55)
sock.ins.send(bytes(CAN(identifier=resp_can_id, flags="extended",
                        data=b'\xff\xff' + b'\x00' * 6)))
res = j1939_scan_dm_pgn(sock, target_da=0x30, pgn=J1939_DM_PGNS["DM1"],
                        dm_name="DM1", sniff_time=0.1)
assert res.supported is False, "Response from wrong SA must be ignored"
assert res.error == "Timeout"
cleanup_testsockets()

= dm_pgn_probe: stop_event already set returns Aborted immediately
def test_dm_pgn_stop_event():
    ev = Event()
    ev.set()
    with TestSocket(CAN) as tx_sock, TestSocket(CAN) as monitor:
        tx_sock.pair(monitor)
        res = j1939_scan_dm_pgn(tx_sock, target_da=0x00,
                                pgn=J1939_DM_PGNS["DM1"],
                                dm_name="DM1", stop_event=ev,
                                sniff_time=0.05)
        probes = monitor.sniff(count=1, timeout=0.1)
        assert len(probes) == 0, "No probe should be sent when stop_event is set"
        assert res.error == "Aborted"
    cleanup_testsockets()

test_dm_pgn_stop_event()


