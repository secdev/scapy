        found = j1939_scan_uds(sock, scan_range=[0x42], sniff_time=0.3,
                               skip_functional=True, src_addrs=[0xF9])
        t.join(timeout=2.0)
        assert 0x42 in found, "Immediate UDS reply must be captured, got: {}".format([hex(k) for k in found])
    cleanup_testsockets()

test_uds_immediate_reply()

= xcp: immediate ECU reply is captured (sniff-before-send regression)
def test_xcp_immediate_reply():
    import threading
    with TestSocket(CAN) as sock, TestSocket(CAN) as monitor:
        sock.pair(monitor)
        def simulate_ecu():
            while True:
                pkts = monitor.sniff(count=1, timeout=1.0)
