= rts_probe: detects Cannot Respond on Acknowledgment PGN from probed node
sock = TestSocket(CAN)
# Cannot Respond (SA=0x44, ctrl=0x03) directed to scanner SA 0xF9
ack_can_id = _j1939_can_id(6, _J1939_PF_ACK, 0xF9, 0x44)
sock.ins.send(bytes(CAN(identifier=ack_can_id, flags="extended",
