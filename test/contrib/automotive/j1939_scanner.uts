= _resolve_probe_sock: callable creates a per-probe socket

def _factory():
    return TestSocket(CAN)

send_sock, rx_sock, close_rx = _resolve_probe_sock(_factory, 0x42)
assert close_rx is True, "Expected close_rx=True for factory-created socket"
assert send_sock is rx_sock, "Factory path should use same socket for send and receive"
rx_sock.close()
cleanup_testsockets()

