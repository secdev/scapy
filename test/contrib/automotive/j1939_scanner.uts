= rts_probe: ignores positive ACK (ctrl=0x00) on Acknowledgment PGN
sock = TestSocket(CAN)
# Positive ACK (ctrl=0x00) should NOT be treated as presence confirmation
ack_can_id = _j1939_can_id(6, _J1939_PF_ACK, 0xF9, 0x45)
sock.ins.send(bytes(CAN(identifier=ack_can_id, flags="extended",
                        data=bytes([0x00, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0x00, 0x00]))))
found = j1939_scan_rts_probe(sock, scan_range=[0x45], sniff_time=0.1, src_addrs=[0xF9])
assert len(found) == 0, "Positive ACK should not trigger RTS probe detection"
cleanup_testsockets()

= rts_probe: ignores non-TP.CM / non-ACK responses
sock = TestSocket(CAN)
# An Address Claimed frame from SA=0x45 should NOT trigger detection
resp_can_id = _j1939_can_id(6, J1939_PF_ADDRESS_CLAIMED, 0xF9, 0x45)
sock.ins.send(bytes(CAN(identifier=resp_can_id, flags="extended",
                        data=b'\x00' * 8)))
found = j1939_scan_rts_probe(sock, scan_range=[0x45], sniff_time=0.1, src_addrs=[0xF9])
assert len(found) == 0, "rts_probe should only respond to TP.CM or ACK frames"
cleanup_testsockets()

= rts_probe: RTS payload has correct format (8 bytes, ctrl=0x10)
def test_rts_probe_payload_format():
    with TestSocket(CAN) as tx_sock, TestSocket(CAN) as monitor:
        tx_sock.pair(monitor)
        j1939_scan_rts_probe(tx_sock, scan_range=[0x50], sniff_time=0.0,
                             src_addrs=[0xF9])
        pkts = monitor.sniff(count=1, timeout=0.2)
        assert len(pkts) == 1
        payload = bytes(pkts[0].data)
        assert len(payload) == 8, "RTS payload must be 8 bytes"
        assert payload[0] == 0x10, "Byte 0 must be TP_CM_RTS (0x10)"
        # Bytes 1-2 LE: message size = 9
        size = struct.unpack_from("<H", payload, 1)[0]
        assert size == 9, "Message size should be 9"
        # Byte 3: total packets = 2
        assert payload[3] == 2, "Total packets should be 2"
    cleanup_testsockets()

test_rts_probe_payload_format()

= rts_probe: returns empty dict when no responses
sock = TestSocket(CAN)
found = j1939_scan_rts_probe(sock, scan_range=[0x10, 0x11], sniff_time=0.02, src_addrs=[0xF9])
assert found == {}
cleanup_testsockets()


+ Top-level j1939_scan combinator

= j1939_scan: raises ValueError for unknown method name
def test_scan_invalid_method():
    sock = TestSocket(CAN)
    try:
        j1939_scan(sock, methods=["invalid_method"])
        assert False, "Expected ValueError"
    except ValueError as e:
        assert "invalid_method" in str(e)
    cleanup_testsockets()

test_scan_invalid_method()

= j1939_scan: merges results from multiple methods; addr_claim is first discoverer
# addr_claim finds SA=0x10 first; unicast also gets a spurious 0x10 response
sock = TestSocket(CAN)
# Response for addr_claim (SA=0x10)
resp_can_id = _j1939_can_id(6, J1939_PF_ADDRESS_CLAIMED, J1939_GLOBAL_ADDRESS, 0x10)
sock.ins.send(bytes(CAN(identifier=resp_can_id, flags="extended",
                        data=b'\x00' * 8)))
# noise_ids=set() bypasses the passive pre-scan, so the pre-injected response
# frame is available for the active addr_claim method to receive.
found = j1939_scan(sock, scan_range=[0x10], methods=["addr_claim", "unicast"],
                   broadcast_listen_time=0.1, sniff_time=0.02, noise_ids=set())
assert 0x10 in found, "SA=0x10 should be found"
# First method that found it should be addr_claim
assert found[0x10]["methods"][0] == "addr_claim", \
    "Expected addr_claim but got {}".format(found[0x10]["methods"][0])
assert isinstance(found[0x10]["packets"], list)
assert len(found[0x10]["packets"]) == 1
assert isinstance(found[0x10]["packets"][0], list)
cleanup_testsockets()

= j1939_scan: result dict has 'methods' and 'packets' keys
sock = TestSocket(CAN)
resp_can_id = _j1939_can_id(6, J1939_PF_ADDRESS_CLAIMED, J1939_GLOBAL_ADDRESS, 0x11)
sock.ins.send(bytes(CAN(identifier=resp_can_id, flags="extended",
                        data=b'\x00' * 8)))
# noise_ids=set() bypasses the passive pre-scan so the pre-injected response is available.
found = j1939_scan(sock, methods=["addr_claim"], broadcast_listen_time=0.1, noise_ids=set())
assert 0x11 in found
assert "methods" in found[0x11], "Expected 'methods' key"
assert "packets" in found[0x11], "Expected 'packets' key"
assert isinstance(found[0x11]["packets"], list), "'packets' must be a list"
assert found[0x11]["methods"] == ["addr_claim"]
assert len(found[0x11]["packets"]) == 1, "Single detection: packets list must have 1 entry"
assert isinstance(found[0x11]["packets"][0], list)
cleanup_testsockets()

= j1939_scan: stop_event halts scan immediately
def test_scan_stop_event():
    from threading import Event
    ev = Event()
    ev.set()  # already set -> should return immediately without any probes
    with TestSocket(CAN) as sock, TestSocket(CAN) as monitor:
        sock.pair(monitor)
        found = j1939_scan(sock, methods=["addr_claim", "unicast"],
                           scan_range=range(0xFE), broadcast_listen_time=0.1,
                           stop_event=ev)
        # stop_event was set before any method ran; no probes should have been sent
        probes = monitor.sniff(count=1, timeout=0.1)
        assert len(probes) == 0, "No probes should be sent when stop_event is set"
    cleanup_testsockets()

test_scan_stop_event()

