                        data=bytes([TP_Conn_Abort, 0x01, 0xFF, 0xFF, 0xFF, 0xFF, 0x00, 0x00]))))
found = j1939_scan_rts_probe(sock, scan_range=[0x41], sniff_time=0.1, src_addrs=[0xF9])
assert 0x41 in found, "Expected SA=0x41 via Conn_Abort reply"
assert isinstance(found[0x41], list)
assert len(found[0x41]) == 1
cleanup_testsockets()

= rts_probe: detects NACK on Acknowledgment PGN from probed node
