                    resp_data = b'\x02\x7e\x00' + b'\xff' * 5
                    resp_id = _j1939_can_id(6, J1939_PF_DIAG_A, sa, ps)
                    sock.ins.send(bytes(CAN(identifier=resp_id, flags="extended", data=resp_data)))
        t = threading.Thread(target=simulate_ecu)
