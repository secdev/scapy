        tx_sock.pair(monitor)
        j1939_scan_xcp(tx_sock, scan_range=[0x20], sniff_time=0.0,
                       noise_ids=set(), src_addrs=[0xF9])
        pkts = monitor.sniff(count=1, timeout=0.2)
        assert len(pkts) == 1, \
            "Expected 1 XCP probe frame, got {}".format(len(pkts))
        _, pf, ps, sa = _j1939_decode_can_id(pkts[0].identifier)
        assert pf == J1939_PF_XCP, \
            "XCP probe should use Physical PF=0xEF, got 0x{:02X}".format(pf)
        assert ps == 0x20, \
            "DA should be 0x20, got 0x{:02X}".format(ps)
