# NACK response (SA=0x42, ctrl=0x01 NACK) directed to scanner SA 0xF9
nack_can_id = _j1939_can_id(6, _J1939_PF_ACK, 0xF9, 0x42)
sock.ins.send(bytes(CAN(identifier=nack_can_id, flags="extended",
                        data=bytes([_ACK_CTRL_NACK, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0x00, 0x00]))))
found = j1939_scan_rts_probe(sock, scan_range=[0x42], sniff_time=0.1, src_addrs=[0xF9])
assert 0x42 in found, "Expected SA=0x42 via NACK reply on ACK PGN"
assert isinstance(found[0x42], list)
assert len(found[0x42]) == 1
cleanup_testsockets()

