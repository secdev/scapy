    found = j1939_scan(sock, methods=["addr_claim"], broadcast_listen_time=0.1,
                       noise_ids={0x70})
    assert 0x70 not in found, "SA=0x70 is in explicit noise_ids and must be suppressed"
    assert 0x71 in found, "SA=0x71 (not noise) should be found"
    cleanup_testsockets()

