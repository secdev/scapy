+ Send-then-sniff race condition regression tests
~ conf

= unicast: immediate ECU reply is captured (sniff-before-send regression)
def test_unicast_immediate_reply():
    import threading
    with TestSocket(CAN) as sock, TestSocket(CAN) as monitor:
        sock.pair(monitor)
        def simulate_ecu():
            while True:
                pkts = monitor.sniff(count=1, timeout=1.0)
                if not pkts:
                    break
                p = pkts[0]
                _, pf, ps, sa = _j1939_decode_can_id(p.identifier)
                if pf == J1939_PF_REQUEST:
                    resp_id = _j1939_can_id(6, J1939_PF_ADDRESS_CLAIMED, J1939_GLOBAL_ADDRESS, ps)
                    sock.ins.send(bytes(CAN(identifier=resp_id, flags="extended", data=b'\x00' * 8)))
        t = threading.Thread(target=simulate_ecu)
        t.start()
        found = j1939_scan_unicast(sock, scan_range=[0x42], sniff_time=0.3, src_addrs=[0xF9])
        t.join(timeout=2.0)
        assert 0x42 in found, "Immediate ECU reply must be captured, got: {}".format([hex(k) for k in found])
    cleanup_testsockets()

test_unicast_immediate_reply()

= rts_probe: immediate ECU reply is captured (sniff-before-send regression)
