                    cts_data = bytes([TP_CM_CTS, 0x01, 0x01, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF])
                    resp_id = _j1939_can_id(7, J1939_TP_CM_PF, sa, ps)
                    sock.ins.send(bytes(CAN(identifier=resp_id, flags="extended", data=cts_data)))
        t = threading.Thread(target=simulate_ecu)
        t.start()
        found = j1939_scan_rts_probe(sock, scan_range=[0x42], sniff_time=0.3, src_addrs=[0xF9])
        t.join(timeout=2.0)
        assert 0x42 in found, "Immediate CTS reply must be captured, got: {}".format([hex(k) for k in found])
    cleanup_testsockets()

test_rts_probe_immediate_reply()

= uds: immediate ECU reply is captured (sniff-before-send regression)
def test_uds_immediate_reply():
    import threading
