from scapy.cborpacket import CBOR_Packet

class UIntExact(CBOR_Packet):
    CBOR_root = CBORF_UNSIGNED_INTEGER('n', 0)

results = []
for val in [0, 1, 10, 23, 24, 255, 256, 65535, 65536, 4294967295]:
    pkt = UIntExact()
    pkt.n.val = val
    results.append(bytes(pkt) == cbor2.dumps(val))

all(results)

