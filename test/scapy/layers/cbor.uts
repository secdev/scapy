        CBORF_TEXT_STRING('data', 'payload'),
    )

pkt = RTPkt()
raw = bytes(pkt)
cbor2_dec = cbor2.loads(raw)
re_enc = cbor2.dumps(cbor2_dec)
pkt2 = RTPkt(re_enc)
pkt2.seq.val == 1 and pkt2.data.val == 'payload'

